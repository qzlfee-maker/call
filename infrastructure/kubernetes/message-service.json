{
  "apiVersion": "apps/v1",
  "kind": "Deployment",
  "metadata": {
    "name": "crane-message-service",
    "labels": {
      "app": "crane-messenger",
      "component": "message-processor"
    }
  },
  "spec": {
    "replicas": 4, 
    "selector": {
      "matchLabels": {
        "component": "message-processor"
      }
    },
    "template": {
      "metadata": {
        "labels": {
          "component": "message-processor"
        }
      },
      "spec": {
        "containers": [
          {
            "name": "message-worker",
            "image": "registry.railway.app/craneapp/server:latest",
            "command": ["node", "server/services/message-service/messageService.js"],
            "env": [
              {
                "name": "DATABASE_URL",
                "valueFrom": { "secretKeyRef": { "name": "crane-db-secrets", "key": "url" } }
              },
              {
                "name": "REDIS_URL",
                "valueFrom": { "secretKeyRef": { "name": "crane-redis-secrets", "key": "url" } }
              },
              {
                "name": "BATCH_SIZE",
                "value": "50"
              }
            ],
            "resources": {
              "requests": {
                "cpu": "200m",
                "memory": "512Mi"
              },
              "limits": {
                "cpu": "500m",
                "memory": "1Gi"
              }
            },
            "livenessProbe": {
              "exec": {
                "command": ["pgrep", "-f", "messageService.js"]
              },
              "initialDelaySeconds": 10,
              "periodSeconds": 15
            }
          }
        ]
      }
    }
  }
}
