{
  "version": "3.8",
  "services": {
    "crane-server": {
      "build": {
        "context": "../../",
        "dockerfile": "infrastructure/docker/serverDockerfile.txt"
      },
      "container_name": "crane_backend",
      "ports": [
        "5000:5000"
      ],
      "environment": {
        "NODE_ENV": "development",
        "DATABASE_URL": "postgresql://crane_admin:crane_password@db:5432/crane_messenger",
        "REDIS_URL": "redis://redis:6379",
        "JWT_SECRET": "crane_super_secret_key_2026",
        "PORT": 5000
      },
      "depends_on": [
        "db",
        "redis"
      ],
      "networks": [
        "crane-network"
      ]
    },

    "crane-client": {
      "build": {
        "context": "../../",
        "dockerfile": "infrastructure/docker/clientDockerfile.txt"
      },
      "container_name": "crane_frontend",
      "ports": [
        "80:80"
      ],
      "depends_on": [
        "crane-server"
      ],
      "networks": [
        "crane-network"
      ]
    },

    "db": {
      "image": "postgres:15-alpine",
      "container_name": "crane_db",
      "environment": {
        "POSTGRES_USER": "crane_admin",
        "POSTGRES_PASSWORD": "crane_password",
        "POSTGRES_DB": "crane_messenger"
      },
      "volumes": [
        "postgres_data:/var/lib/postgresql/data"
      ],
      "networks": [
        "crane-network"
      ]
    },

    "redis": {
      "image": "redis:7-alpine",
      "container_name": "crane_redis",
      "networks": [
        "crane-network"
      ]
    }
  },

  "networks": {
    "crane-network": {
      "driver": "bridge"
    }
  },

  "volumes": {
    "postgres_data": {}
  }
}
