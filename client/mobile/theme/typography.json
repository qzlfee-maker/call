{
  "name": "Craneapp Typography System",
  "fontFamily": {
    "sans": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
    "mono": "'SF Mono', 'Fira Code', 'Ubuntu Mono', monospace",
    "chat": "'Inter', system-ui"
  },
  "scale": {
    "h1": {
      "size": "24px",
      "weight": "700",
      "lineHeight": "1.2",
      "letterSpacing": "-0.02em"
    },
    "h2": {
      "size": "20px",
      "weight": "600",
      "lineHeight": "1.3"
    },
    "body": {
      "large": {
        "size": "17px",
        "weight": "400",
        "lineHeight": "1.5"
      },
      "medium": {
        "size": "15px",
        "weight": "400",
        "lineHeight": "1.4"
      },
      "small": {
        "size": "13px",
        "weight": "400",
        "lineHeight": "1.4"
      }
    },
    "message": {
      "text": "16px",
      "time": "11px",
      "author": "14px",
      "weight": "400"
    },
    "caption": {
      "size": "12px",
      "weight": "500",
      "textTransform": "uppercase",
      "letterSpacing": "0.05em"
    }
  },
  "adaptive": {
    "ios_optimized": true,
    "android_optimized": true
  }
}
